{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": null
  },
  "deploy": {
    "startCommand": "npm run cron:release-expired",
    "cronSchedule": "0 3 * * *",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
