# RARE STORE - exemplo seguro de ambiente
# Copie para .env somente no ambiente local. Nunca versionar .env.
# Na Railway, configure estes valores em Service > Variables.
# Todos os valores abaixo sao placeholders; substitua antes de homologacao real.

# Ambiente
# Dev local: development. Producao/preview gerenciado normalmente usa production.
NODE_ENV="development"

# Banco de dados
# Banco oficial atual: Neon via DATABASE_URL.
# Obrigatoria em dev e producao. Use uma URL PostgreSQL real apenas no .env local
# ou nas variaveis do servico Railway.
DATABASE_URL="replace-with-postgresql-database-url"

# Banco shadow do Prisma, usado por `prisma migrate dev`.
# Deve apontar para um banco limpo e separado do DATABASE_URL.
# Em Postgres local, se template1 estiver contaminado, crie o shadow a partir de
# template0 e nunca aponte para template0/template1 diretamente.
SHADOW_DATABASE_URL="replace-with-clean-shadow-postgresql-database-url"

# URL canonica da aplicacao
# NEXT_PUBLIC_APP_URL e publico e vai para o bundle do browser.
# APP_URL e server-side e deve apontar para a mesma origem em producao.
# Dominio oficial comprado: raredept.com.br.
# Use https://raredept.com.br como placeholder inicial; www pode virar alias/redirect
# conforme configuracao final no provedor.
NEXT_PUBLIC_APP_URL="https://raredept.com.br"
APP_URL="https://raredept.com.br"

# E-mails planejados da loja (documentacao operacional, nao SMTP):
# caixa principal: contato@raredept.com.br
# aliases/redirecionamentos: suporte@raredept.com.br e pedidos@raredept.com.br

# Admin/sessao
# ADMIN_SESSION_SECRET e o nome atual usado pelo app. AUTH_SECRET tambem e aceito
# como alias server-side. Use 32+ caracteres aleatorios; nao use este placeholder.
ADMIN_SESSION_SECRET="replace-with-random-32-plus-character-secret"
AUTH_SECRET=""
ADMIN_EMAIL="contato@raredept.com.br"
ADMIN_PASSWORD="replace-with-strong-admin-password"

# Checkout Stripe
# Em dev sem Stripe real, mantenha CHECKOUT_ENABLED=false.
# Em staging/homologacao online, defina CHECKOUT_ENABLED=true apenas na Railway
# junto com chaves de teste configuradas em Service > Variables.
# Com CHECKOUT_ENABLED=true, STRIPE_SECRET_KEY e STRIPE_WEBHOOK_SECRET sao obrigatorias.
CHECKOUT_ENABLED="false"
STRIPE_SECRET_KEY="replace-with-stripe-test-secret-key"
STRIPE_WEBHOOK_SECRET="replace-with-stripe-test-webhook-secret"

# Deixe vazio para metodos dinamicos configurados no Dashboard Stripe.
# Use card,pix somente depois de confirmar elegibilidade do Pix na conta Stripe.
STRIPE_PAYMENT_METHOD_TYPES=""
STRIPE_PRICE_CURRENCY="BRL"

# Notificacoes Admin no celular (Web Push)
# Gere as chaves com: npm run webpush:keys
# NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY e publica e vai para o browser.
# WEB_PUSH_VAPID_PRIVATE_KEY e secret server-side e deve ficar apenas na Railway.
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""
WEB_PUSH_CONTACT="mailto:contato@raredept.com.br"

# Storage de uploads
# App em producao: Railway.
# Upload em producao: server-side para Cloudflare R2. O browser envia para
# /api/admin/uploads e o servidor Next na Railway grava no R2 com credenciais server-side.
# Limite operacional: 4 MB por arquivo.
# O filesystem local do container Railway nao persiste imagens enviadas pelo Admin.
# Para dev local sem R2, use STORAGE_DRIVER="local" e STORAGE_PUBLIC_BASE_URL="/uploads".
STORAGE_DRIVER="r2"
UPLOAD_DRIVER=""
STORAGE_LOCAL_DIR="public/uploads"
STORAGE_PUBLIC_BASE_URL=""
MAX_UPLOAD_SIZE_MB="4"
MAX_GIF_UPLOAD_SIZE_MB="4"
MAX_VIDEO_UPLOAD_SIZE_MB="4"

# Override temporario, somente se o responsavel aceitar o risco em homologacao.
ALLOW_LOCAL_STORAGE_IN_PRODUCTION="false"

# Cloudflare R2, usado quando STORAGE_DRIVER=r2.
# Nao coloque credenciais reais neste arquivo. Configure valores reais apenas
# nas variaveis do ambiente Railway.
R2_ACCOUNT_ID=""
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BASE_URL=""

# Rate limit
# memory e suficiente para dev/testes. Para producao aberta, use driver
# compartilhado via Redis REST/Upstash para proteger multiplas instancias.
RATE_LIMIT_DRIVER="memory"
# Producao: RATE_LIMIT_DRIVER="redis" com as variaveis abaixo configuradas
# no provedor de ambiente. Nao coloque token real neste arquivo.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Alternativas aceitas quando o provedor nao usa o prefixo UPSTASH:
REDIS_REST_URL=""
REDIS_REST_TOKEN=""
RATE_LIMIT_REDIS_PREFIX="rare:rate-limit"

# Frete automatico - Melhor Envio
# Provider principal da RARE em producao/homologacao quando o token estiver valido.
# O app tambem aceita MELHOR_ENVIO_ACCESS_TOKEN. CLIENT_ID/CLIENT_SECRET sozinhos
# nao bastam sem autorizacao OAuth finalizada.
SHIPPING_PROVIDER="melhor_envio"
# Fallback operacional quando StoreSettings.originCep ainda nao estiver definido.
SHIPPING_ORIGIN_CEP="31170350"
MELHOR_ENVIO_TOKEN=""
MELHOR_ENVIO_ACCESS_TOKEN=""
MELHOR_ENVIO_CLIENT_ID=""
MELHOR_ENVIO_CLIENT_SECRET=""
MELHOR_ENVIO_REDIRECT_URI=""
MELHOR_ENVIO_ENV="production"
MELHOR_ENVIO_BASE_URL=""
MELHOR_ENVIO_SERVICES="1,2"
MELHOR_ENVIO_USER_AGENT="RARE Store (raredept.com.br)"

# Railway Cron
# Usado por /api/cron/release-expired-inventory para liberar reservas vencidas.
# Configure 32+ caracteres aleatorios na Railway; nao reutilize segredos de auth.
CRON_SECRET="replace-with-random-32-plus-character-cron-secret"

# Confirmacoes explicitas para scripts perigosos em producao
CONFIRM_PRODUCTION_SEED="false"
CONFIRM_PRODUCTION_ADMIN="false"
