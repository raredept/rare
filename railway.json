{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "preDeployCommand": "PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=true npx prisma migrate deploy",
    "startCommand": "PORT=${PORT:-3000} HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
